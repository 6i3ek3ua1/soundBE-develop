# Конфигурационный файл SoundBE
# Настройки можно переопределить через переменные окружения

LOG_FILE=test.log
LOG_LEVEL=DEBUG

# Порт для веб-интерфейса
UI_PORT=8000

# ID устройства захвата аудио (пустое значение - запросить вручную)
AUDIO_DEVICE=

# Модель для перевода (простая заглушка для тестирования)
TRANSLATION_MODEL=stub

# Язык для синтеза речи
TTS_LANGUAGE=en

# Использовать vLLM для перевода (true/false, по умолчанию false для совместимости)
USE_VLLM=false